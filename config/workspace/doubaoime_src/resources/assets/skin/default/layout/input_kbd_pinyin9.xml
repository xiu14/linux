                        <ButtonChar text="TUV" class="cls_keyboard9_button" ficon_text="8"
                            keycode="0x38"
                            fusiyin_keycode="0x3038" fusiyin_bubble_text="T U V 8 t u v"
                            fusiyin_bubble_keycode="0x1054 0x1055 0x1056 0x3038 0x0054 0x0055 0x0056"
                            long_press_bubble_text="t u v T U V 8"
                            long_press_bubble_keycode="0x0054 0x0055 0x0056 0x1054 0x1055 0x1056 0x3038" />
                    </VerticalLayout>

                    <VerticalLayout height="match_parent" width_weight="77">
                        <ButtonChar text="DEF" class="cls_keyboard9_button" ficon_text="3"
