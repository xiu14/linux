                        <ButtonChar text="MNO" class="cls_keyboard9_button" ficon_text="6"
                            keycode="0x36"
                            fusiyin_keycode="0x3036" fusiyin_bubble_text="M N O 6 m n o"
                            fusiyin_bubble_keycode="0x104D 0x104E 0x104F 0x3036 0x004D 0x004E 0x004F"
                            long_press_bubble_text="m n o M N O 6"
                            long_press_bubble_keycode="0x004D 0x004E 0x004F 0x104D 0x104E 0x104F 0x3036" />
                        <ButtonChar text="WXYZ" class="cls_keyboard9_button" ficon_text="9"
                            keycode="0x39"
                            fusiyin_keycode="0x3039" fusiyin_bubble_text="W X Y Z 9 w x y z"
                            fusiyin_bubble_keycode="0x1057 0x1058 0x1059 0x105A 0x3039 0x0057 0x0058 0x0059 0x005A"
