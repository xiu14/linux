                            long_press_bubble_keycode="0x0057 0x0058 0x0059 0x005A 0x1057 0x1058 0x1059 0x105A 0x3039" />
                    </VerticalLayout>
                </HorizontalLayout>
                <!-- 52 = 44 + 8 （高度44 + 间距8） -->
                <HorizontalLayout width="match_parent" height_weight="52">
                    <ButtonSwitchBoard class="cls_keyboard9_button_func_white_circle" text="123" target="5"
                        width_weight="45.5" height="match_parent" name="button_switch_123"/>
                    <Container width_weight="134" height="match_parent" mouse="false">
                        <ButtonSpace name="space_speech" class="cls_button_space, cls_keyboard9_button_margin"
                            ficon_text="0" fusiyin_keycode="0x3030"/>
                        <Button name="space_speech_loading" visible="false" mouse="false" float="true"
                            width="33" height="20" gravity="center|vcenter"
                            normalimage="file='drawable/voice_space.gif'" />
                    </Container>
                    <ButtonSwitchChineseEnglish target="english"
                        class="cls_button_cn2en, cls_keyboard9_button_margin, cls_bk_white_circle"
                        width_weight="45.5" height="match_parent" name="button_en2ch"/>
                </HorizontalLayout>
            </VerticalLayout>

            <!-- 66 = 61 + 2.5 + 2.5（左2.5右2.5margin）-->
            <VerticalLayout height="match_parent" width_weight="66">
                <ButtonBackspace name="backspace"
                    class="cls_button_backspace, cls_keyboard9_button_margin" />
                <ButtonReset text="重输" class="cls_keyboard9_button_func" name="button_reset"/>
                <VerticalLayout width="match_parent" height_weight="2">
                    <ButtonEnter name="button_enter" class="cls_button_enter9" />
                </VerticalLayout>
            </VerticalLayout>
        </HorizontalLayout>
    </Pinyin9Layout>
</Window>
