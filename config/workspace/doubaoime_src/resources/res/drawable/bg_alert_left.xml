<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <size
                android:height="50dp"
                android:width="100dp"/>
            <corners android:radius="12dp"/>
            <solid android:color="@color/color_black_twenty_four_percent"/>
        </shape>
    </item>
    <item>
        <shape>
            <size
                android:height="50dp"
                android:width="100dp"/>
            <corners android:radius="12dp"/>
            <solid android:color="@color/alter_left"/>
        </shape>
    </item>
</selector>
