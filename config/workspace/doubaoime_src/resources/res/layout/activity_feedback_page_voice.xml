<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/oui_p_container_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.obric.oui.sectiontitlebar.OSectionTitleBar
            android:id="@+id/feedback_context_tip_voice"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oui_titleText="@string/upload_feedback_tips"
            app:oui_useBadgeView="false"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/feedback_groups_container_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
