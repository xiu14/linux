<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/relativeLayout"
            android:background="@android:color/white"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp">
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/icon_feedback_back"
                android:layout_alignTop="@+id/tv_title"
                android:layout_alignBottom="@+id/tv_title"/>
            <TextView
                android:textSize="18dp"
                android:typeface="monospace"
                android:textStyle="bold"
                android:textColor="@color/color_title_tv"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
        <androidx.core.widget.NestedScrollView
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="28dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_problem_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">
                    <TextView
                        android:textSize="14dp"
                        android:textColor="@color/color_999999"
                        android:id="@+id/tv_priori"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="20dp"
                        android:paddingEnd="6dp"/>
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/iv_question"
                        android:visibility="gone"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/feedbacker_question"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_priori"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_recurrence"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recurrence"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_classification"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:text="模块分类"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_classification"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_advice"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_advice"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_custom"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_custom"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:nestedScrollingEnabled="false"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/color_999999"
                    android:id="@+id/tv_remarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"/>
                <RelativeLayout
                    android:background="#f7f8fa"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp">
                    <com.bytedance.feedbackerlib.view.CustomEditText
                        android:textSize="15sp"
                        android:textColorHint="@color/color_999999"
                        android:gravity="start|top"
                        android:id="@+id/et_feedback"
                        android:background="@null"
                        android:paddingLeft="15dp"
                        android:paddingTop="15dp"
                        android:paddingRight="15dp"
                        android:paddingBottom="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="不能愉快的使用现有功能？上传相关页面截图能方便我们快速解决问题哦～"
                        android:minLines="6"
                        android:maxLength="201"
                        android:paddingEnd="15dp"/>
                    <TextView
                        android:textColor="#a1a8b2"
                        android:id="@+id/tv_word_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="15dp"
                        android:layout_alignRight="@+id/et_feedback"
                        android:layout_alignBottom="@+id/et_feedback"
                        android:layout_alignEnd="@+id/et_feedback"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_photos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="5dp"
                        android:layout_below="@+id/et_feedback"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"/>
                </RelativeLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <TextView
            android:textColor="#c9c9c9"
            android:gravity="center"
            android:id="@+id/tv_get_problem"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="10dp"
            android:text="反馈遇到问题？前往飞书 内测值班号 告诉我们"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
        <TextView
            android:textSize="18dp"
            android:textColor="@color/T2"
            android:gravity="center"
            android:id="@+id/tv_submit"
            android:background="@drawable/background_submit_tv_unavailable_new"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="50dp"
            android:text="提交反馈"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
    </LinearLayout>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/fl_progress_bar_container"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/background_uploading"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="21dp"
            android:paddingEnd="21dp">
            <TextView
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:id="@+id/tv_progress_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上传中..."/>
        </LinearLayout>
    </FrameLayout>
    <RelativeLayout
        android:layout_gravity="center"
        android:id="@+id/rl_toast_container"
        android:background="@drawable/round_toast"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/tv_toast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</FrameLayout>
