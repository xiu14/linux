<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/ime_color_setting_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.obric.oui.titlebar.OCTitleBar
        android:id="@+id/settings_main_title_bar"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="@dimen/oui_h_title_bar_window"
        app:oui_title_text="@string/voice_feedback"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="@dimen/oui_p_container_2"
            android:paddingRight="@dimen/oui_p_container_2"
            android:paddingBottom="@dimen/oui_p_container_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.obric.oui.sectiontitlebar.OSectionTitleBar
                android:background="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:oui_titleText="@string/upload_feedback_tips"
                app:oui_useBadgeView="false"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/voice_recognition_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_feedback_voice_recognition_result_title"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/voice_recognition_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_feedback_voice_recognition_time"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/voice_task_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/voice_feedback_task_id"/>
            <com.obric.oui.forms.OFormItem
                android:orientation="vertical"
                android:id="@+id/feedback_content"
                android:background="@drawable/o_background_list_item"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"/>
            <com.bytedance.android.input.common.views.ScrollableOListItemGeneral
                android:id="@+id/enable_upload_before_context"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_before_context"/>
            <com.bytedance.android.input.common.views.ScrollableOListItemGeneral
                android:id="@+id/enable_upload_after_context"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_after_context"/>
            <com.bytedance.android.input.common.views.ScrollableOListItemGeneral
                android:id="@+id/upload_dialog_history"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_dialog_history"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/upload_words_history"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_words_history"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/upload_voice_modification_history"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_voice_modification_history"/>
            <com.obric.oui.lisitem.OListItemGeneral
                android:id="@+id/upload_voice_record_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                app:oui_list_item_title="@string/upload_voice_record_file"/>
            <com.obric.oui.button.OButton
                android:id="@+id/btn_voice_feedback_commit"
                android:background="@color/theme_color"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/oui_gv_list_item_settings"
                android:text="@string/commit"
                app:oui_radius="10dp"
                style="@style/OButton.L1.Standard.Primary"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
