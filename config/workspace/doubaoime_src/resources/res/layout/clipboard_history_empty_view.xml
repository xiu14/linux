<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/common_phrase_empty"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/clipboard_common_phrase_toolbar_height">
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/clipboard_empty_view_container"
        android:background="@drawable/bg_common_phrase_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="11dp"
        android:layout_marginVertical="7dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatImageView
                android:background="@drawable/bg_clipboard_history_empty_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_clip"
                android:scaleType="centerInside"/>
            <com.obric.oui.text.OTextView
                android:textSize="@dimen/dp_14"
                android:textColor="@color/oui_text_3b"
                android:layout_gravity="center_horizontal"
                android:id="@+id/textview_middle_first"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_14"
                android:text="无剪切内容"
                style="@style/BtnLabel_M2"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
