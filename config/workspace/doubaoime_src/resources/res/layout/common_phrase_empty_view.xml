<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/common_phrase_empty"
    android:background="@drawable/bg_common_phrase_empty"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="11dp"
    android:layout_marginVertical="7dp">
    <ScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <RelativeLayout
            android:gravity="center"
            android:id="@+id/phrase_empty_view_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/common_phrase_empty_img"
                android:background="@drawable/bg_no_phrase_img"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/img_no_phrase"
                android:scaleType="centerInside"
                android:layout_centerHorizontal="true"/>
            <com.obric.oui.text.OTextView
                android:textSize="@dimen/dp_14"
                android:textColor="@color/oui_text_3b"
                android:id="@+id/textview_middle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/common_phrase_empty"
                android:layout_below="@+id/common_phrase_empty_img"
                android:layout_centerHorizontal="true"
                style="@style/BtnLabel_M2"/>
            <TextView
                android:textSize="13dp"
                android:textColor="@color/ime_on_accent_text_1"
                android:gravity="center"
                android:id="@+id/btn_bottom_add_phrase"
                android:background="@drawable/bg_common_phrase_add_btn"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:text="添加常用语"
                android:layout_below="@+id/textview_middle"
                android:layout_centerHorizontal="true"
                android:paddingHorizontal="25dp"
                android:textFontWeight="600"/>
        </RelativeLayout>
    </ScrollView>
</LinearLayout>
