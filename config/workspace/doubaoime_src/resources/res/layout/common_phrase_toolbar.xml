<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/common_phrase_toolbar"
    android:background="@color/navigation_bar_normal"
    android:layout_width="match_parent"
    android:layout_height="@dimen/clipboard_common_phrase_toolbar_height"
    android:paddingHorizontal="11dp">
    <ImageView
        android:id="@+id/btn_close_clipboard_history"
        android:background="@drawable/bg_toolbar_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_toolbar_close"
        android:scaleType="centerInside"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"/>
    <com.obric.oui.text.OTextView
        android:textSize="16dp"
        android:textColor="@color/oui_text_1"
        android:id="@+id/clipboard_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="常用语"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:lineHeight="22dp"
        android:textFontWeight="500"/>
    <ImageView
        android:id="@+id/btn_add_common_phrase"
        android:background="@drawable/bg_toolbar_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_toolbar_add"
        android:scaleType="centerInside"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"/>
</RelativeLayout>
