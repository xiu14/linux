<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/round_feedbacker_dialog"
    android:paddingBottom="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18dp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:textColor="@color/T1"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="问题上报失败"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="13sp"
        android:textColor="#666666"
        android:gravity="center"
        android:id="@+id/tv_feedback_fail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_below="@+id/tv_title"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_below="@+id/tv_feedback_fail">
        <TextView
            android:textSize="18dp"
            android:gravity="center"
            android:id="@+id/tv_confirm"
            android:background="@drawable/round_product_tag"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/feedback_fail_toast_container"
        android:background="@drawable/round_toast"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/tv_feedback_fail_toast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</RelativeLayout>
