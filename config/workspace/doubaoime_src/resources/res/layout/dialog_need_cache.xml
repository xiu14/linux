<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/round_feedbacker_dialog"
    android:paddingBottom="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="18dp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:textColor="#14171a"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_below="@+id/tv_title">
        <TextView
            android:textSize="18dp"
            android:gravity="center"
            android:id="@+id/tv_abandon"
            android:background="@drawable/round_product_tag"
            android:layout_width="117dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"/>
        <TextView
            android:textSize="18dp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/tv_save"
            android:background="@drawable/background_submit_tv_available"
            android:layout_width="117dp"
            android:layout_height="44dp"/>
    </LinearLayout>
</RelativeLayout>
