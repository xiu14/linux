<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/bottom_toolbar"
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:elevation="1dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/T1"
            android:id="@+id/button_preview"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/originalLayout"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/button_preview">
            <com.bytedance.feedbackerlib.matisse.internal.ui.widget.CheckRadioView
                android:layout_gravity="center_vertical"
                android:id="@+id/original"
                android:layout_width="16dp"
                android:layout_height="16dp"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/T1"
                android:layout_gravity="center_vertical"
                android:id="@+id/tv_origin"
                android:paddingLeft="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/button_original"
                android:paddingStart="4dp"
                android:layout_marginStart="2dp"/>
        </LinearLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/button_apply"
            android:background="@drawable/background_submit_tv_available"
            android:paddingTop="3.5dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="20dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <FrameLayout
        android:id="@+id/container"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_toolbar"
        android:layout_below="@+id/toolbar"/>
    <FrameLayout
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_toolbar"
        android:layout_below="@+id/toolbar">
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/album.emptyView.textColor"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/empty_view_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_text"
            android:drawableTop="?attr/album.emptyView"
            android:drawablePadding="8dp"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/fl_background"
        android:background="#7f000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="2dp"/>
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:background="#ffffff"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="3dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/feedbacker_close"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="18sp"
                android:typeface="monospace"
                android:textStyle="bold"
                android:textColor="@color/T1"
                android:gravity="center"
                android:id="@+id/selected_album"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:drawableRight="@drawable/feedbacker_down_arrow_new"
                android:layout_centerInParent="true"
                android:drawableEnd="@drawable/feedbacker_down_arrow_new"/>
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>
</RelativeLayout>
