<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.feedbackerlib.matisse.internal.ui.widget.PreviewViewPager
        android:id="@+id/pager"
        android:background="@android:color/black"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/bottom_toolbar"
        android:background="@color/preview_bottom_toolbar_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:elevation="4dp">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="20dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="36dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp">
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:id="@+id/originalLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.bytedance.feedbackerlib.matisse.internal.ui.widget.CheckRadioView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/original"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>
                    <TextView
                        android:enabled="true"
                        android:textSize="16sp"
                        android:textColor="?attr/preview.bottomToolbar.back.textColor"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/tv_origin"
                        android:paddingLeft="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/button_original"
                        android:paddingStart="4dp"/>
                </LinearLayout>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/preview_bottom_size"
                    android:layout_gravity="center"
                    android:id="@+id/size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <TextView
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:id="@+id/button_apply"
                android:background="@drawable/background_submit_tv_available"
                android:paddingTop="5dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="16dp"
                android:layout_alignParentRight="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="16dp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/top_toolbar"
        android:background="@color/preview_bottom_toolbar_bg"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_alignParentTop="true">
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/preview.bottomToolbar.back.textColor"
            android:layout_gravity="start|bottom"
            android:id="@+id/button_back"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginBottom="1dp"
            android:text=" "
            android:drawableLeft="@drawable/feedbacker_arrow_left"
            android:drawableStart="@drawable/feedbacker_arrow_left"
            android:layout_marginStart="5dp"/>
        <com.bytedance.feedbackerlib.matisse.internal.ui.widget.CheckView
            android:layout_gravity="bottom|right"
            android:id="@+id/check_view"
            android:padding="10dp"
            android:layout_width="24dp"
            android:layout_height="22dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="7dp"
            android:layout_marginEnd="13dp"/>
    </FrameLayout>
</RelativeLayout>
