<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.feedbackerlib.view.CustomScrollView
        android:layout_gravity="end|bottom"
        android:id="@+id/sv_float_window_feedbacker"
        android:background="@drawable/background_feedback_container_init"
        android:scrollbars="none"
        android:layout_width="@dimen/float_window_initial_width"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/bottom_safe_distance"
        android:layout_marginEnd="@dimen/left_and_right_safe_distance">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/ll_float_window_feedbacker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:translationY="0dp">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_up_screen_shot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_floatwindow_camera"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_up_screen_shot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="截屏"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_up_screen_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="29dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_video"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_up_screen_record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="录屏"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_up_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="29dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_feedbacker"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_up_feedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="反馈"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
            <View
                android:id="@+id/view_up_line"
                android:background="#19ffffff"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_up_hide_window"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_hide"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_up_hide_window"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="隐藏"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_float_window_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/ll_float_window_feedback_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iv_floatwindow_feedback"
                        android:layout_width="24dp"
                        android:layout_height="22dp"
                        android:src="@drawable/feedbacker_float_window_initial"/>
                    <TextView
                        android:textSize="10dp"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:id="@+id/tv_float_window_feedback"
                        android:layout_width="wrap_content"
                        android:layout_height="14dp"
                        android:text="反馈"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/ll_float_window_feedback_shrink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp">
                    <View
                        android:background="#19ffffff"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"/>
                    <TextView
                        android:textSize="10dp"
                        android:textColor="@android:color/white"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="14dp"
                        android:text="免遮挡"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_down_hide_window"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="29dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_hide"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_down_hide_window"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="隐藏"/>
            </LinearLayout>
            <View
                android:id="@+id/view_down_line"
                android:background="#19ffffff"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="25dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_down_screen_shot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_floatwindow_camera"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_down_screen_shot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="截屏"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_down_screen_record"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="29dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_video"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_down_screen_record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="录屏"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_down_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="29dp"
                android:layout_marginBottom="25dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="22dp"
                    android:src="@drawable/feedbacker_feedbacker"/>
                <TextView
                    android:textSize="10dp"
                    android:textColor="@android:color/white"
                    android:gravity="center"
                    android:id="@+id/tv_down_feedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="反馈"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.bytedance.feedbackerlib.view.CustomScrollView>
    <TextView
        android:layout_width="@dimen/float_window_initial_width"
        android:layout_height="10dp"/>
    <com.bytedance.feedbackerlib.view.SupportCustomInterceptLinearLayout
        android:layout_gravity="end|top"
        android:orientation="vertical"
        android:id="@+id/ll_float_pic_video"
        android:background="@drawable/background_float_pic_video"
        android:padding="3dp"
        android:visibility="invisible"
        android:layout_width="@dimen/float_pic_video_width"
        android:layout_height="@dimen/float_pic_video_height">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <com.bytedance.feedbackerlib.view.RoundAngleImageView
                android:id="@+id/image_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:roundHeightx="6dp"
                app:roundWidthx="6dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:layout_gravity="end|bottom"
                android:id="@+id/tv_video_length"
                android:background="@drawable/round_tv_video_length"
                android:paddingBottom="1dp"
                android:layout_width="wrap_content"
                android:layout_height="14dp"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginEnd="8dp"/>
        </FrameLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginLeft="2dp"
                android:src="@drawable/feedbacker_upload"
                android:layout_marginStart="2dp"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:id="@+id/text_view"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </com.bytedance.feedbackerlib.view.SupportCustomInterceptLinearLayout>
    <com.bytedance.feedbackerlib.view.SupportCustomInterceptLinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_record_pregress"
        android:background="@drawable/background_progress_container"
        android:visibility="invisible"
        android:layout_width="@dimen/record_process_container_width"
        android:layout_height="@dimen/record_process_container_height">
        <TextView
            android:textSize="16dp"
            android:textColor="@android:color/white"
            android:id="@+id/tv_record_progress"
            android:layout_width="27dp"
            android:layout_height="24dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="12dp"
            android:text="10s"/>
        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="10dp">
            <FrameLayout
                android:layout_gravity="center"
                android:layout_width="28dp"
                android:layout_height="28dp">
                <ProgressBar
                    android:layout_gravity="center"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:max="100"
                    android:progress="100"
                    android:progressDrawable="@drawable/drawable_circle_progress_bar_behind"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <ProgressBar
                    android:layout_gravity="center"
                    android:id="@+id/progress_bar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:max="100"
                    android:progress="88"
                    android:progressDrawable="@drawable/drawable_circle_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"/>
            </FrameLayout>
            <TextView
                android:layout_gravity="center"
                android:background="@drawable/background_progress_red_center"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="8dp"/>
        </FrameLayout>
    </com.bytedance.feedbackerlib.view.SupportCustomInterceptLinearLayout>
</FrameLayout>
