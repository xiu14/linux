<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/ime_color_setting_bg"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.bytedance.common_biz.ui.widget.ImeTitleBar
        android:id="@+id/settings_title_bar"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="@dimen/ime_dp_56"
        app:ime_back_arrow_icon="@drawable/ic_arrow_left"
        app:ime_title_text="@string/desktop_title"/>
    <ScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginTop="@dimen/ime_dp_30"
                android:src="@drawable/desktop_ime_logo"/>
            <ImageView
                android:layout_width="143dp"
                android:layout_height="60dp"
                android:layout_marginTop="@dimen/ime_dp_12"
                android:src="@drawable/desktop_sub_title"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:background="@drawable/bg_desktop_download_card"
                android:paddingTop="@dimen/ime_dp_13"
                android:paddingBottom="@dimen/ime_dp_22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ime_dp_34"
                android:layout_marginHorizontal="@dimen/dp_20">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="13dp">
                            <ImageView
                                android:layout_width="@dimen/ime_dp_18"
                                android:layout_height="@dimen/ime_dp_18"
                                android:src="@drawable/ic_desktop_macos"/>
                            <TextView
                                android:textSize="@dimen/ime_sp_16"
                                android:textColor="@color/desktop_platform_primary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/ime_dp_8"
                                android:text="@string/desktop_macos"
                                android:includeFontPadding="false"
                                android:letterSpacing="0.04"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:layout_gravity="top|right"
                            android:background="@drawable/bg_desktop_new_label"
                            android:layout_width="@dimen/ime_dp_29"
                            android:layout_height="@dimen/ime_dp_12"
                            android:layout_marginRight="5dp">
                            <TextView
                                android:textSize="@dimen/ime_dp_7"
                                android:textStyle="bold"
                                android:textColor="@color/ime_color_white"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/desktop_new_label"
                                android:includeFontPadding="false"/>
                        </LinearLayout>
                    </FrameLayout>
                    <View
                        android:background="@color/desktop_divider"
                        android:layout_width="1px"
                        android:layout_height="@dimen/ime_dp_14"/>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingVertical="13dp">
                        <ImageView
                            android:layout_width="@dimen/ime_dp_15"
                            android:layout_height="@dimen/ime_dp_15"
                            android:src="@drawable/ic_desktop_windows"/>
                        <TextView
                            android:textSize="@dimen/ime_sp_16"
                            android:textColor="@color/desktop_platform_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/ime_dp_7"
                            android:text="@string/desktop_windows"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.04"/>
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:background="@color/desktop_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1px"/>
                <TextView
                    android:textSize="@dimen/ime_sp_14"
                    android:textColor="@color/ime_color_common_text_73_color"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ime_dp_18"
                    android:text="@string/desktop_official_site_tip"
                    android:includeFontPadding="false"/>
                <TextView
                    android:textSize="@dimen/ime_sp_23"
                    android:textStyle="bold"
                    android:textColor="@color/ime_color_common_text_d9_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ime_dp_5"
                    android:text="@string/desktop_official_site"
                    android:includeFontPadding="false"/>
                <TextView
                    android:textSize="@dimen/ime_sp_14"
                    android:textColor="@color/ime_color_4f84ff"
                    android:gravity="center"
                    android:id="@+id/desktop_copy_button"
                    android:background="@drawable/bg_desktop_copy_button"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ime_dp_18"
                    android:text="@string/desktop_copy_url"
                    android:includeFontPadding="false"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
