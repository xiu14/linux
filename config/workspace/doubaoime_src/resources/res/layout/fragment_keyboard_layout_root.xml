<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/keyboard_layout_root"
    android:background="@drawable/bg_setting_group"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/ime_dp_17"
    android:paddingVertical="@dimen/ime_dp_22">
    <TextView
        android:textSize="@dimen/ime_sp_15"
        android:textStyle="bold"
        android:textColor="@color/ime_color_common_text_d9_color"
        android:id="@+id/title_set"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/developer_keyboard_speech"/>
</LinearLayout>
