                    android:id="@+id/enable_fuzzy_initial_consonant_s_list_item"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ime_dp_6"
                    app:accessoryType="switch_button"
                    app:auto_height="true"
                    app:containerBackgroundColor="@color/ime_color_setting_item_bg"
                    app:containerCornerRadius="@dimen/ime_dp_15"
