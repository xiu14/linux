<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/ime_sp_16"
        android:textStyle="bold"
        android:textColor="@color/ime_color_common_text_d9_color"
        android:id="@+id/item_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:lineSpacingMultiplier="1.36"
        android:layout_alignParentStart="true"/>
    <com.bytedance.common_biz.ui.widget.ImeCheckBox
        android:id="@+id/item_checkbox"
        android:layout_width="@dimen/ime_dp_22"
        android:layout_height="@dimen/ime_dp_22"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
