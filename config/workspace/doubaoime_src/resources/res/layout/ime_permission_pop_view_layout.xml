<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/ime_dp_20">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_permission_pop_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/ime_dp_20"
        android:paddingVertical="@dimen/ime_dp_16">
        <ImageView
            android:id="@+id/ime_permission_icon"
            android:background="@drawable/ic_doubao_input_36"
            android:layout_width="@dimen/ime_dp_39"
            android:layout_height="@dimen/ime_dp_39"
            android:contentDescription="@null"
            android:layout_marginEnd="@dimen/ime_dp_8"/>
        <LinearLayout
            android:gravity="start|center_vertical"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:gravity="start"
                android:id="@+id/ime_permission_title_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/PermissionPopTitle"/>
            <TextView
                android:gravity="start"
                android:id="@+id/ime_permission_desc_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ime_dp_6"
                android:maxLines="2"
                style="@style/PermissionPopDescription"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
