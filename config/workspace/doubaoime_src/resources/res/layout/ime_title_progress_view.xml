<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/progress_root"
    android:background="@drawable/bg_setting_group"
    android:paddingTop="@dimen/ime_dp_22"
    android:paddingBottom="@dimen/ime_dp_22"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/ime_dp_16">
    <RelativeLayout
        android:id="@+id/progress_item_top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textStyle="bold"
            android:textColor="@color/ime_color_common_text_d9_color"
            android:id="@+id/progress_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            style="@style/misans_demibold_16px"/>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/progress_item_switch"
            android:background="@drawable/switch_custom_thumb"
            android:visibility="gone"
            android:layout_width="@dimen/ime_dp_46"
            android:layout_height="@dimen/ime_dp_32"
            android:thumb="@null"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            app:track="@null"/>
    </RelativeLayout>
    <com.bytedance.common_biz.ui.widget.ImeStepSlider
        android:id="@+id/progress_item_step"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ime_dp_22"
        app:stepSliderStyle="step"/>
    <com.bytedance.common_biz.ui.widget.ImeStepSlider
        android:id="@+id/progress_item_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ime_dp_16"
        app:labelColor="@color/ime_keyboard_progress_text_color"
        app:stepSliderStyle="progress"/>
</LinearLayout>
