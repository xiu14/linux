<?xml version="1.0" encoding="utf-8"?>
<com.bytedance.feedbackerlib.matisse.internal.ui.widget.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_photo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:scaleType="center"/>
    <TextView
        android:textSize="12sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_gravity="end|bottom"
        android:id="@+id/tv_video_length"
        android:background="@drawable/round_video_length"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="4dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginEnd="12dp"/>
    <ImageView
        android:layout_gravity="end|top"
        android:id="@+id/iv_close"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/icon_close_photo"/>
</com.bytedance.feedbackerlib.matisse.internal.ui.widget.SquareFrameLayout>
