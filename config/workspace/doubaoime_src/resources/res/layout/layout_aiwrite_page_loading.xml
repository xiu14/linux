<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.obric.oui.progress.ODownloadProgressView
            android:id="@+id/aiwrite_loading_anim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oui_progress_view_size="large"/>
        <com.obric.oui.text.OTextView
            android:textColor="@color/oui_text_3b"
            android:id="@+id/aiwrite_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_10"
            android:text="正在检查..."
            style="@style/Title_Title_M"/>
    </LinearLayout>
</LinearLayout>
