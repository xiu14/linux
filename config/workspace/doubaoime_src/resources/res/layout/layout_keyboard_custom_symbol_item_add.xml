<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ime_dp_46">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/ime_dp_11"
            android:layout_height="@dimen/ime_dp_11"
            android:src="@drawable/ic_common_add"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/ime_dp_10"
            android:textColor="@color/ime_custom_symbol_item_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/ime_dp_2"
            android:text="@string/keyboard_custom_symbol"
            android:includeFontPadding="false"
            android:fontFamily="@font/qihei"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
