<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/voice_tip_bk"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_speech_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/root_linear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:gravity="left"
                    android:id="@+id/text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="编辑文字或标点时，你可以说"
                    android:singleLine="true"
                    android:fontFamily="@font/roboto"
                    style="@style/textview_speech_tip_title"/>
                <TextView
                    android:gravity="left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/speech_command_tip_1"
                    android:singleLine="true"
                    style="@style/textview_speech_tip_text"/>
                <TextView
                    android:gravity="left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speech_command_tip_2"
                    android:singleLine="true"
                    style="@style/textview_speech_tip_text"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/second_linear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <TextView
                    android:gravity="left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="编辑文本格式，你可以说"
                    android:singleLine="true"
                    android:fontFamily="@font/roboto"
                    style="@style/textview_speech_tip_title"/>
                <TextView
                    android:gravity="left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/speech_command_tip_3"
                    android:singleLine="true"
                    style="@style/textview_speech_tip_text"/>
                <TextView
                    android:gravity="left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speech_command_tip_4"
                    android:singleLine="true"
                    style="@style/textview_speech_tip_text"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_alert_right"
            android:background="@drawable/btn_shape"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="好的"
            android:textFontWeight="600"
            style="@style/textview_speech_tip_text"/>
    </LinearLayout>
</LinearLayout>
