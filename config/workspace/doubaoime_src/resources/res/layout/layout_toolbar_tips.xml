<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/ime_dp_13"
        android:textColor="@color/ime_toolbar_tips_text_color"
        android:id="@+id/toolbar_tips"
        android:background="@drawable/bg_toolbar_tips"
        android:paddingTop="@dimen/ime_dp_7"
        android:paddingBottom="@dimen/ime_dp_7"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/keyboard_toolbar_tips"
        android:singleLine="true"
        android:includeFontPadding="false"
        android:paddingStart="@dimen/ime_dp_12"
        android:paddingEnd="@dimen/ime_dp_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
