<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/ime_sp_16"
        android:textColor="@color/ime_color_common_text_d9_color"
        android:id="@+id/item_text"
        android:background="@drawable/bg_corner_6_gray"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:lineSpacingMultiplier="1.36"
        android:layout_alignParentStart="true"
        android:paddingHorizontal="@dimen/dp_10"/>
    <com.bytedance.common_biz.ui.widget.ImeCheckBox
        android:id="@+id/item_checkbox"
        android:layout_width="@dimen/ime_dp_22"
        android:layout_height="@dimen/ime_dp_22"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        app:noSelectRes="@drawable/ic_checkbox_rectangle_no_select"
        app:selectRes="@drawable/ic_checkbox_rectangle_select"/>
</RelativeLayout>
