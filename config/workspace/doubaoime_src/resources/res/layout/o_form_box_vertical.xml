<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/BGPrimary"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title_container"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/input_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.obric.oui.text.OTextView
            android:textStyle="bold"
            android:textColor="@color/TextTertiary"
            android:id="@+id/tv_title"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oui_textSpec="P2"/>
        <ImageView
            android:id="@+id/iv_title_icon"
            android:visibility="gone"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/o_ic_required"
            android:layout_marginStart="2dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/input_container"
        android:background="@drawable/o_bg_float_form"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="@+id/title_container"
        app:layout_constraintTop_toBottomOf="@+id/title_container"
        app:layout_goneMarginTop="0dp">
        <RelativeLayout
            android:id="@+id/prefix_container"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/edittext"
            app:layout_constraintHeight_default="wrap"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/edittext"/>
        <com.obric.oui.forms.OFormEditText
            android:scrollbarSize="3dp"
            android:scrollbarThumbVertical="@drawable/o_scrollbar"
            android:textColor="@color/oui_text_1"
            android:textColorHighlight="@color/oui_text_highlight_color"
            android:textColorHint="@color/oui_text_4"
            android:gravity="top"
            android:id="@+id/edittext"
            android:background="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:visibility="visible"
            android:scrollbars="vertical"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:lines="3"
            android:textCursorDrawable="@drawable/o_form_default_cursor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_default="wrap"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/prefix_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_weight="1"
            style="@style/BtnLabel_M2_Thin"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.obric.oui.text.OTextView
        android:textColor="@color/Negative"
        android:id="@+id/tv_error_tips"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@+id/input_container"
        app:layout_constraintTop_toBottomOf="@+id/input_container"
        app:oui_textSpec="T1"/>
    <com.obric.oui.text.OTextView
        android:textColor="@color/TextQuaternary"
        android:id="@+id/tv_counter"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="@+id/input_container"
        app:layout_constraintTop_toBottomOf="@+id/input_container"
        app:oui_textSpec="T1"/>
</merge>
