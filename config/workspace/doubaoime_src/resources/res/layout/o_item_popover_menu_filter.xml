<?xml version="1.0" encoding="utf-8"?>
<com.obric.oui.popover.menu.PopoverMenuLinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minHeight="44dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/item_container"
        android:paddingLeft="@dimen/oui_p_list_item_1"
        android:paddingRight="@dimen/oui_g_list_item_1"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.obric.oui.radio.ORadio
            android:id="@+id/popover_menu_radio"
            android:visibility="gone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="-4dp"
            android:layout_marginEnd="12dp"
            app:oui_radioStyle="check"/>
        <ImageView
            android:id="@+id/iv_popover_action"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/oui_p_list_item_1"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingTop="@dimen/oui_g_list_item_1"
            android:paddingBottom="@dimen/oui_g_list_item_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <com.obric.oui.text.OTextView
                android:textColor="@color/oui_text_1"
                android:ellipsize="end"
                android:id="@+id/tv_popover_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                style="@style/Title_Title_M"/>
            <com.obric.oui.text.OTextView
                android:textColor="@color/oui_text_3"
                android:ellipsize="end"
                android:id="@+id/tv_popover_action_sub"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                style="@style/Label_M_Thin"/>
        </LinearLayout>
        <com.obric.oui.text.OTextView
            android:textColor="@color/oui_text_3"
            android:ellipsize="end"
            android:id="@+id/tv_popover_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="4dp"
            style="@style/Label_L"/>
        <ImageView
            android:id="@+id/iv_popover_tail_image"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>
</com.obric.oui.popover.menu.PopoverMenuLinearLayout>
