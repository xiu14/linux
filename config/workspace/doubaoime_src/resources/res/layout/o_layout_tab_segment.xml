<?xml version="1.0" encoding="utf-8"?>
<com.obric.oui.segmentedtab.OSegmentTabView xmlns:android="http://schemas.android.com/apk/res/android"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_tap"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:gravity="center_horizontal"
            android:id="@+id/tv_tab_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"/>
        <com.obric.oui.text.OBaseTextView
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/tv_tab_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>
    <com.obric.oui.segmentedtab.UnReadMsgView xmlns:mv="http://schemas.android.com/apk/res-auto"
        android:textSize="11.5sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/rtv_msg_tip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/ll_tap"
        mv:mv_backgroundColor="#fd481f"
        mv:mv_isRadiusHalfHeight="true"
        mv:mv_strokeColor="#ffffff"
        mv:mv_strokeWidth="1dp"/>
</com.obric.oui.segmentedtab.OSegmentTabView>
