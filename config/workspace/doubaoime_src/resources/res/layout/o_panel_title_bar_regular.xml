<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="12dp"
    android:focusable="false"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/panel_expand_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/icon_right_24_24_icon_as_action"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.obric.oui.text.OTextView
        android:textColor="@color/oui_text_1"
        android:id="@+id/panel_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/panel_expand_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginLeft="8dp"
        style="@style/Title_Title_M_Thick"/>
    <ImageView
        android:id="@+id/panel_info_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:src="@drawable/ic_info_20_20_text3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/panel_title"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.obric.oui.text.OTextView
        android:textColor="@color/oui_text_3"
        android:id="@+id/panel_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        app:layout_constraintBaseline_toBaselineOf="@+id/panel_title"
        app:layout_constraintLeft_toRightOf="@+id/panel_info_icon"
        app:layout_goneMarginLeft="6dp"
        style="@style/Label_M_Thin"/>
    <FrameLayout
        android:id="@+id/panel_action_container"
        android:paddingLeft="4dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/panel_info"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</merge>
