<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="@dimen/oui_p_container_1"
    android:paddingBottom="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sheet_title_bar_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="32dp"
        app:layout_constraintBottom_toTopOf="@+id/sheet_title_bar_des"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_left_action_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/oui_p_title_bar_default"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.obric.oui.text.OTextView
                android:textColor="@color/oui_text_1"
                android:gravity="center"
                android:id="@+id/left_title"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                style="@style/Title_Title_L"/>
            <com.obric.oui.button.OButton
                android:id="@+id/left_action_back"
                android:visibility="visible"
                android:clickable="true"
                app:icon="@drawable/o_ic_titlebar_back"
                style="@style/OButton.M1.Trans.Neutral"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_right_action_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/oui_p_title_bar_default"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <FrameLayout
            android:id="@+id/fl_center_action_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ll_right_action_container"
            app:layout_constraintStart_toEndOf="@+id/ll_left_action_container"
            app:layout_constraintTop_toTopOf="parent">
            <com.obric.oui.text.OTextView
                android:textColor="@color/oui_text_2"
                android:gravity="center"
                android:id="@+id/center_title"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="8dp"
                style="@style/Title_Title_M"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/fl_fixed_center_action_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.obric.oui.text.OTextView
                    android:textColor="@color/oui_text_1"
                    android:layout_gravity="center"
                    android:id="@+id/fixed_center_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="216dp"
                    android:paddingHorizontal="@dimen/oui_p_list_item_2"
                    style="@style/Title_Title_M_Thick"/>
                <com.obric.oui.text.OTextView
                    android:textColor="@color/oui_text_3b"
                    android:layout_gravity="center"
                    android:id="@+id/fixed_center_sub_title"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    style="@style/Label_S"/>
            </LinearLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/sheet_title_bar_des"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sheet_title_bar_main">
        <com.obric.oui.text.OTextView
            android:textColor="@color/oui_text_2"
            android:layout_gravity="center"
            android:id="@+id/sheet_title_bar_des_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Body_M"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
