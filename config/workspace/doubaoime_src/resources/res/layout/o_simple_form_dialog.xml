<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.obric.oui.text.OTextView
            android:textColor="@color/oui_text_1"
            android:gravity="center"
            android:id="@+id/simple_form_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            style="@style/Title_Title_M"/>
        <com.obric.oui.text.OTextView
            android:textColor="@color/oui_text_2"
            android:gravity="center"
            android:id="@+id/simple_form_subtitle"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:maxLines="2"
            style="@style/Body_M"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/simple_form_body_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:paddingBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">
            <com.obric.oui.forms.OInputView
                android:id="@+id/simple_form_input_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:oui_showLabel="false"/>
            <com.obric.oui.forms.OInputView
                android:id="@+id/simple_form_input_2"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:oui_showLabel="false"/>
        </LinearLayout>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/simple_form_footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">
            <com.obric.oui.button.OButton
                android:id="@+id/simple_form_button_1"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_weight="1"
                style="@style/OButton.L1.Standard.Neutral"/>
            <com.obric.oui.button.OButton
                android:id="@+id/simple_form_button_2"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_marginLeft="12dp"
                android:layout_weight="1"
                style="@style/OButton.L1.Standard.Primary"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
