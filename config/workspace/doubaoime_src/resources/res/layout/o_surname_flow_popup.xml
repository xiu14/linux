<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/surname_container"
        android:paddingLeft="10dp"
        android:paddingTop="1.5dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ScrollView
            android:layout_gravity="center"
            android:id="@+id/surname_content_frame"
            android:background="@drawable/surname_popup_background"
            android:paddingLeft="6dp"
            android:paddingTop="16dp"
            android:paddingRight="6dp"
            android:paddingBottom="16dp"
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:overScrollMode="always">
            <smartisan.widget.letters.SurnameFlowLayout
                android:layout_gravity="top|center_horizontal"
                android:id="@+id/surname_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </ScrollView>
    </LinearLayout>
    <ImageView
        android:layout_gravity="top"
        android:id="@+id/surname_top_mask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="17.5dp"
        android:src="@drawable/surname_mask_top"
        android:scaleType="fitXY"/>
    <ImageView
        android:layout_gravity="bottom"
        android:id="@+id/surname_bottom_mask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/surname_mask_bottom"
        android:scaleType="fitXY"/>
    <ImageView
        android:layout_gravity="bottom"
        android:id="@+id/surname_popup_bottom_arrow"
        android:background="@drawable/surname_popup_arrow_bottom"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ImageView
        android:layout_gravity="top"
        android:id="@+id/surname_popup_top_arrow"
        android:background="@drawable/surname_popup_arrow_up"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
