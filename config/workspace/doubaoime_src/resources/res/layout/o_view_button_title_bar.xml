<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/oui_title_bar_height">
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="start|center_vertical"
        android:id="@+id/back_btn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/o_ic_titlebar_back"
        android:scaleType="centerInside"
        android:tint="@color/oui_fill_icon_as_action"
        android:contentDescription="@string/oui_iv_back_desc"
        style="@style/o_back_btn_padding"/>
    <com.obric.oui.text.OTextView
        android:textColor="@color/oui_text_1"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:id="@+id/title"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="264dp"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        style="@style/Title_Title_M"/>
    <com.obric.oui.text.OTextView
        android:textSize="15dp"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/right_btn"
        android:padding="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:maxLines="1"
        android:layout_marginEnd="12dp"/>
    <com.obric.oui.divider.ODivider
        android:layout_gravity="bottom"
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</merge>
