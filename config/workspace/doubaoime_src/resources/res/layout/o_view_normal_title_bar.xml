<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/oui_title_bar_height">
    <com.obric.oui.text.OTextView
        android:textSize="17dp"
        android:textColor="@color/oui_text_1"
        android:ellipsize="end"
        android:layout_gravity="start|center_vertical"
        android:id="@+id/text_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/oui_p_title_bar_default"
        android:maxWidth="100dp"
        android:maxLines="1"
        android:layout_marginStart="@dimen/oui_p_title_bar_default"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="start|center_vertical"
        android:id="@+id/back_btn"
        android:layout_width="@dimen/oui_w_button_icon_m1"
        android:layout_height="@dimen/oui_h_m1"
        android:layout_marginLeft="@dimen/oui_p_title_bar_default"
        android:src="@drawable/o_ic_titlebar_back"
        android:tint="@color/oui_fill_icon_as_action"
        android:contentDescription="@string/oui_iv_back_desc"
        android:layout_marginStart="@dimen/oui_p_title_bar_default"
        android:paddingHorizontal="@dimen/oui_p_button_m1"/>
    <com.obric.oui.text.OTextView
        android:textColor="@color/oui_text_1"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:id="@+id/title"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="264dp"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        style="@style/Title_Title_M"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="end|center_vertical"
        android:id="@+id/right_btn"
        android:layout_width="@dimen/oui_w_button_icon_m1"
        android:layout_height="@dimen/oui_h_m1"
        android:layout_marginRight="@dimen/oui_p_title_bar_default"
        android:contentDescription="@string/oui_more_desc"
        android:layout_marginEnd="@dimen/oui_p_title_bar_default"
        android:paddingHorizontal="@dimen/oui_p_button_m1"/>
    <com.obric.oui.divider.ODivider
        android:layout_gravity="bottom"
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</FrameLayout>
