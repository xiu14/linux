<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_container"
    android:background="@drawable/praise_dialog_bg"
    android:layout_width="270dp"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textColor="@color/market_feedback_title_color"
        android:gravity="center"
        android:id="@+id/market_feedback_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/praise_dialog_title"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="15sp"
        android:gravity="center"
        android:id="@+id/market_feedback_dialog_tips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/praise_dialog_tips"
        android:layout_below="@+id/market_feedback_dialog_title"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/market_feedback_dialog_center"
        android:background="@drawable/ic_praise_good"
        android:visibility="visible"
        android:layout_width="240dp"
        android:layout_height="150dp"
        android:layout_marginTop="30dp"
        android:layout_below="@+id/market_feedback_dialog_tips"
        android:layout_centerHorizontal="true"/>
    <View
        android:id="@+id/market_feedback_divider"
        android:background="@color/market_feedback_divider_color"
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_alignTop="@+id/market_feedback_bottom_layout"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/market_feedback_bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="35dp"
        android:weightSum="2"
        android:layout_below="@+id/market_feedback_dialog_center">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/market_feedback_title_color"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_market_feedback_dialog_complaint"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/praise_dialog_complaint"
            android:layout_weight="1"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_market_feedback_dialog_praise"
            android:background="@drawable/praise_dialog_praise_bg"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/praise_dialog_praise"
            android:layout_weight="1"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/market_feedback_dialog_close"
        android:paddingLeft="4dp"
        android:paddingTop="4dp"
        android:paddingRight="4dp"
        android:paddingBottom="4dp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_praise_dialog_close"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
