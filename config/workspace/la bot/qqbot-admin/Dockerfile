FROM python:3.11-slim

WORKDIR /app

# 安装 Docker CLI (用于重启容器)
RUN apt-get update && apt-get install -y docker.io && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY . .

# 暴露端口
EXPOSE 5000

# 启动命令
CMD ["python", "app.py"]
